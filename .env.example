# =============================================================================
# Shared environment — copy this file to .env and fill in your values.
# python-dotenv's load_dotenv() searches upward, so scripts in any subfolder
# pick it up automatically.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure AI Foundry  (required by 04-hosting_a2a/ and a2a_agent_as_function_tools.py)
# Run `az login` before starting the server — no API key needed, uses CLI auth.
# -----------------------------------------------------------------------------
FOUNDRY_PROJECT_ENDPOINT=https://your-project.services.ai.azure.com/api/projects/your-project
FOUNDRY_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# A2A server URL  (used by 02-agents_a2a/ client scripts)
# Point this at whichever server you started:
#   04-hosting_a2a invoice agent   → http://localhost:5000/
#   04-hosting_a2a policy agent    → http://localhost:5001/
#   04-hosting_a2a logistics agent → http://localhost:5002/
#   demo/ CalculatorAgent          → http://localhost:5001/
# -----------------------------------------------------------------------------
A2A_AGENT_HOST=http://localhost:5001/
